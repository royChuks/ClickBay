/* Backup of original main.css - Created on 2025-01-12 */
*{
    box-sizing:border-box;
}

:root{
    --primary-color: #1E90FF; /* dogerblue*/
    --secondary-color: darkslategrey;/* darkslategray*/
    --background-color : #ffffff; /* Cornsilk White*/
}
html{
    margin: auto;
}
body{
    font-family: Arial, sans-serif;
    background-color: var(--background-color);
    margin: 0;
    padding: 0;
    width: 100%;
}

nav{
    background-color: var(--primary-color);
    margin: 0 auto;
    padding: 0;
}

nav ul li a{
    color: var(--background-color);
}
nav ul li a:hover{
    background-color: var(--secondary-color);
}

h1{
    display: flex;
    align-items: center;    
    justify-content: space-between;
    color:darkslategrey;
    background-color: var(--background-color);
    font-weight: 400;
}
.container{
    text-align:center;
    margin:50px;
}

.carousel-container{
    position: relative;
    padding: 10px;
    overflow-x: scroll;
    scroll-behavior:initial;
    display: flex;
}

.carousel-track{
    display: grid;
    grid-template-columns: repeat(4, 1fr);  
    gap:20px;
    padding: 20px;
    transition:  transform 0 5s ease-in-out;
}

.card{
    flex: 0 0;
    width: 300px;
    height: 150px;
    background: var(--secondary-color);
    border-radius: 8px;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 1.5);
    font-weight: bold;
    padding: 16px;
    color: var(--background-color);
}

.arrow{
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: var(--secondary-color);
    color: var(--background-color);
    border: none;
    padding: 10px;
    cursor: pointer;
    z-index: 1;
    border-radius: 20px 20px;
    display: none;
}
.arrow:hover{
    background-color:var(--primary-color) ;
}
.arrow.left{
    left: 0;
}
.arrow.right{
    right: 0;
}
.ai-search-container{
    display: flex;
    justify-content: center;
    align-items: center;
    margin-top: 100px;
    width: 700px;
    position: relative;
    left: 8cm;
}
.ai-search-box{
    width: 300px;
    padding: 10px;
    border: 1px solid var(--primary-color);
    font-size: 6px;
    outline: none;
    border-radius: 20px 0 0 20px;
    color: darkcyan;
    margin: 0;
    background-color: black
}
.ai-search-button{
    padding: 10px 20px;
    border:none;
    cursor: pointer;
    font-size: 16px;
    border-radius: 0 20px 20px 0;
    background-color:var(--secondary-color) ;
    color: #ffffff;;
}

.ai-search-button:hover{
    background-color: #375abd;
}

.popup{
    display: none;
    position: absolute;
    top: 0;
    left: 110px; /*postion to the write of the button*/
    background-color: var(--primary-color);
    border: 1px solid grey;
    border-radius: 6px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
    white-space: no-wrap;
}
.popup.show{
    display: block;
}
