NODE_ENV=development
PORT=4000
HOST=localhost
LOG_LEVEL=info
JWT_SECRET=replace_with_minimum_32_characters
JWT_EXPIRY=15m
REFRESH_TOKEN_SECRET=replace_with_minimum_32_characters
REFRESH_TOKEN_EXPIRY=7d
DB_HOST=localhost
DB_PORT=5432
DB_USER=clickbay_user
DB_PASSWORD=secure_password_here
DB_NAME=clickbay_dev
DB_POOL_MIN=2
DB_POOL_MAX=20
DB_SSL=false
NEO4J_URL=neo4j://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_password_here
NEO4J_DB=neo4j
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
VECTOR_DB_TYPE=milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_DB_NAME=clickbay
PINECONE_API_KEY=
PINECONE_INDEX_NAME=
OPENAI_API_KEY=
LLM_MODEL=gpt-4
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048
SCRAPER_TIMEOUT=30000
SCRAPER_MAX_SIZE=10485760
SCRAPER_USER_AGENT=ClickBay/1.0
SCRAPER_RATE_LIMIT=10
SCRAPER_CONCURRENT_JOBS=5
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW=15m
RATE_LIMIT_MAX_REQUESTS=100
BCRYPT_ROUNDS=12
SENTRY_DSN=
LOG_FORMAT=json
LOG_DESTINATION=console
ENABLE_SUBSCRIPTIONS=true
ENABLE_GRAPHRAG=true
ENABLE_SEMANTIC_SEARCH=true
ENABLE_RATE_LIMITING=true
ENABLE_CACHING=true
